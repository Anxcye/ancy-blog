# File: .env.example
# Purpose: Provide local environment variable template for backend development.
# Module: backend runtime configuration template.
# Related: internal/config, Makefile run/migrate commands, dockerized PostgreSQL/Redis.

APP_NAME=ancy-blog-api
APP_ENV=dev

HTTP_HOST=0.0.0.0
HTTP_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,http://localhost:5173,http://127.0.0.1:5173

AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=123456
AUTH_ACCESS_TOKEN_TTL_SECONDS=3600
AUTH_REFRESH_TOKEN_TTL_SECONDS=604800

DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=ancy_blog
DB_USER=ancy
DB_PASSWORD=ancy_dev_password
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=5

REDIS_ENABLED=false
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=2

TRANSLATION_WORKER_ENABLED=true
TRANSLATION_WORKER_POLL_INTERVAL_MS=3000
TRANSLATION_WORKER_BACKOFF_BASE_MS=3000
TRANSLATION_WORKER_BACKOFF_MAX_MS=60000
