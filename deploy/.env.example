# File: .env.example
# Purpose: Provide production environment variables for Docker Compose deployment.
# Module: deploy runtime configuration template.
# Related: deploy/docker-compose.yml, backend/.env.example, deploy/release.sh.

APP_DOMAIN=example.com
ADMIN_DOMAIN=admin.example.com
ACME_EMAIL=ops@example.com
APP_IMAGE_TAG=latest
TZ=Asia/Shanghai

AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=change_me
AUTH_ACCESS_TOKEN_TTL_SECONDS=3600
AUTH_REFRESH_TOKEN_TTL_SECONDS=604800

DB_NAME=ancy_blog
DB_USER=ancy
DB_PASSWORD=change_me
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=5

REDIS_ENABLED=true
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=2

CORS_ALLOWED_ORIGINS=https://example.com,https://admin.example.com

TRANSLATION_WORKER_ENABLED=true
TRANSLATION_WORKER_POLL_INTERVAL_MS=3000
TRANSLATION_WORKER_BACKOFF_BASE_MS=3000
TRANSLATION_WORKER_BACKOFF_MAX_MS=60000
