(common_overrides) {
  import /etc/caddy/local/*.caddy
}

(common_tls) {
  tls {$ORIGIN_CERT_FILE} {$ORIGIN_KEY_FILE}
}

{$APP_DOMAIN} {
  import common_overrides
  import common_tls

  encode zstd gzip

  @api path /api/*
  handle @api {
    reverse_proxy backend:8080
  }

  handle {
    reverse_proxy frontend-blog:3000
  }
}

{$ADMIN_DOMAIN} {
  import common_overrides
  import common_tls

  encode zstd gzip

  @api path /api/*
  handle @api {
    reverse_proxy backend:8080
  }

  handle {
    reverse_proxy admin:80
  }
}
